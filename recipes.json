    {
      "id": "20260722-191326",
      "title": "なすのトルコ風詰め物",
      "source_url": "https://yomuno.jp/posts/140274",
      "source_name": "ヨムーノ",
      "image": "images/20260722-191326.jpg",
      "servings": "2人分",
      "folders": [
        "おかず",
        "おつまみ"
      ],
      "ingredients": [
        {
          "item": "なす",
          "quantity": "4",
          "unit": "本",
          "note": "ヘタを取り縦3か所ほど皮を剥く"
        },
        {
          "item": "ベーコン",
          "quantity": "30",
          "unit": "g",
          "note": "5mm角に切る"
        },
        {
          "item": "玉ねぎ",
          "quantity": "1/2",
          "unit": "個",
          "note": "みじん切り"
        },
        {
          "item": "ピーマン",
          "quantity": "1",
          "unit": "個",
          "note": "みじん切り"
        },
        {
          "item": "にんにく",
          "quantity": "1",
          "unit": "片",
          "note": "みじん切り"
        },
        {
          "item": "パセリ",
          "quantity": "",
          "unit": "",
          "note": "少々・細かく刻む"
        },
        {
          "item": "塩",
          "quantity": "",
          "unit": "",
          "note": "適宜"
        },
        {
          "item": "胡椒",
          "quantity": "",
          "unit": "",
          "note": "適宜"
        },
        {
          "item": "クミン",
          "quantity": "1",
          "unit": "小さじ",
          "note": ""
        },
        {
          "item": "オレガノ",
          "quantity": "1",
          "unit": "小さじ",
          "note": ""
        },
        {
          "item": "チリパウダー",
          "quantity": "",
          "unit": "",
          "note": "少々"
        },
        {
          "item": "オリーブオイル",
          "quantity": "1",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "揚げ油",
          "quantity": "",
          "unit": "",
          "note": "分量外・素揚げ用"
        }
      ],
      "steps": [
        "ベーコンは5mm角に切る。玉ねぎ・ピーマン・にんにくはみじん切り、パセリも細かく刻んでおく。",
        "フライパンにオリーブオイルを熱し、ベーコン・玉ねぎ・ピーマン・にんにくを中火で炒める。全体に火が通ったら塩・胡椒・クミン・オレガノ・チリパウダーを加え、スパイスが焦げないよう弱火で馴染ませるように炒め合わせる。",
        "炒めた具材をボウルに移し、刻んだパセリを混ぜ合わせる。",
        "なすはヘタを取り、ピーラーで縦に3か所ほど皮を剥く。フライパンに油（分量外）を入れ弱〜中火にかけ、丸ごと素揚げして全体がやわらかくなるまで7〜8分火を通す（揚げたては熱いので注意）。",
        "揚げたなすに縦の切り込みを入れ、3の具材をたっぷり詰める。180℃に予熱したオーブンで約5分焼いたら完成。食べるときは大きめに切ると食べやすい。"
      ],
      "memo": "出典：丸大食品「なすのトルコ風詰め物」（ヨムーノ記事）。素揚げしたなすにスパイス炒めの具材を詰めてオーブンで焼くトルコの家庭料理。クミン・オレガノ・チリパウダーで一気に異国風、少しピリ辛。ヘタは付けたままでもOK（その場合はよく洗う）。副菜にもメインにもなるボリューム。",
      "cooking_time": "",
      "created_at": "2026-07-22T19:13:26+09:00",
      "updated_at": "2026-07-22T19:13:26+09:00"
    },
    {
