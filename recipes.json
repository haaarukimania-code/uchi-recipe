    {
      "id": "20260720-000001",
      "title": "ぶち簡単!キャベツのアンチョビ炒め",
      "source_url": "",
      "source_name": "サンプル",
      "image": "",
      "servings": "2人分",
      "folders": [
        "イタリアン"
      ],
      "cooking_time": "10分",
      "ingredients": [
        {
          "item": "キャベツ",
          "quantity": "1/4",
          "unit": "個",
          "note": ""
        },
        {
          "item": "アンチョビフィレ",
          "quantity": "3",
          "unit": "枚",
          "note": ""
        },
        {
          "item": "にんにく",
          "quantity": "1",
          "unit": "片",
          "note": "みじん切り"
        },
        {
          "item": "オリーブオイル",
          "quantity": "2",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "鷹の爪",
          "quantity": "",
          "unit": "",
          "note": "お好みで"
        },
        {
          "item": "塩",
          "quantity": "",
          "unit": "",
          "note": "味をみて"
        }
      ],
      "steps": [
        "キャベツをざく切りにする。",
        "フライパンにオリーブオイル・にんにく・鷹の爪を入れて弱火で香りを出す。",
        "アンチョビを加えて木べらでほぐし、キャベツを入れて中火で炒める。",
        "キャベツがしんなりしたら味をみて、足りなければ塩で調える。"
      ],
      "memo": "サンプルレシピ。取り込みスキルができたら実データに置き換える。",
      "created_at": "2026-07-20T12:00:00+09:00",
      "updated_at": "2026-07-20T12:00:00+09:00"
    },
    {
      "id": "20260720-000002",
      "title": "肉じゃが",
      "source_url": "",
      "source_name": "サンプル",
      "image": "",
      "servings": "大人2子供2人分",
      "folders": [
        "和食"
      ],
      "cooking_time": "40分",
      "ingredients": [
        {
          "item": "牛薄切り肉",
          "quantity": "200",
          "unit": "g",
          "note": ""
        },
        {
          "item": "じゃがいも",
          "quantity": "4",
          "unit": "個",
          "note": "一口大に切る"
        },
        {
          "item": "玉ねぎ",
