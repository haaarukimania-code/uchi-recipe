    {
      "id": "20260720-181220",
      "title": "漬けズッキーニ",
      "source_url": "https://yomuno.jp/posts/140451",
      "source_name": "ヨムーノ",
      "image": "images/20260720-181220.jpg",
      "servings": "2〜3人分",
      "folders": [
        "常備菜"
      ],
      "ingredients": [
        {
          "item": "ズッキーニ",
          "quantity": "1",
          "unit": "本",
          "note": "5mm幅の薄切り"
        },
        {
          "item": "白ごま",
          "quantity": "1",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "砂糖",
          "quantity": "1",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "ごま油",
          "quantity": "1",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "しょうゆ",
          "quantity": "2",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "酢",
          "quantity": "2",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "水",
          "quantity": "30",
          "unit": "ml",
          "note": ""
        }
      ],
      "steps": [
        "ズッキーニ以外の材料をすべて保存容器に入れ、よく混ぜ合わせる。",
        "ズッキーニを5mm幅の薄切りにする（厚さをなるべく均一に）。",
        "調味料を混ぜた保存容器にズッキーニを入れる。",
        "ラップを表面に密着させて、調味液に触れる面積を増やす。",
        "冷蔵室で30分ほど漬けて完成。"
      ],
      "memo": "厚くなりすぎると味が染みにくくなるため、なるべく均一にカットするのがポイント。\n仕上げに糸唐辛子や七味をお好みで。\n（脱サラ料理家ふらお）",
      "created_at": "2026-07-20T18:12:20+09:00",
      "updated_at": "2026-07-20T18:12:20+09:00",
      "cooking_time": "30分（漬け時間）"
    },
