        },
        {
          "item": "かつおぶし",
          "quantity": "1",
          "unit": "袋",
          "note": "2g"
        },
        {
          "item": "酢",
          "quantity": "1",
          "unit": "大さじ",
          "note": "【A】"
        },
        {
          "item": "白すりごま",
          "quantity": "1/2",
          "unit": "大さじ",
          "note": "【A】"
        },
        {
          "item": "ごま油",
          "quantity": "1/2",
          "unit": "大さじ",
          "note": "【A】"
        },
        {
          "item": "砂糖",
          "quantity": "1/2",
          "unit": "小さじ",
          "note": "【A】"
        },
        {
          "item": "生姜",
          "quantity": "1/2",
          "unit": "小さじ",
