      "id": "20260720-000001",
      "title": "ぶち簡単!キャベツのアンチョビ炒め",
      "source_url": "",
      "source_name": "サンプル",
      "image": "",
      "servings": "2人分",
      "folders": [
        "イタリアン"
      ],
      "cooking_time": "10分",
      "ingredients": [
        {
          "item": "キャベツ",
          "quantity": "1/4",
          "unit": "個",
          "note": ""
        },
        {
          "item": "アンチョビフィレ",
          "quantity": "3",
          "unit": "枚",
          "note": ""
        },
        {
          "item": "にんにく",
          "quantity": "1",
          "unit": "片",
          "note": "みじん切り"
        },
        {
          "item": "オリーブオイル",
          "quantity": "2",
          "unit": "大さじ",
