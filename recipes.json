          "note": "乱切り"
        },
        {
          "item": "しらたき",
          "quantity": "1",
          "unit": "袋",
          "note": "下茹でする"
        },
        {
          "item": "サラダ油",
          "quantity": "1",
          "unit": "大さじ",
          "note": ""
        },
        {
          "item": "だし汁",
          "quantity": "400",
          "unit": "ml",
